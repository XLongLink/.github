---
/* 
Footer for Aurelius Photography portfolio
*/
---

<footer class="border-t border-base-content/5 py-12 px-8 bg-base-100">
	<div class="flex flex-col md:flex-row justify-between items-end md:items-center gap-8">
		<!-- Left: Identity & Core Info -->
		<div class="space-y-6">
			<div class="space-y-1">
				<span class="block text-2xl font-swiss tracking-tighter leading-none">LONGLINK</span>
				<span class="font-tech text-[8px] opacity-30 tracking-[0.4em]">SYSTEMS_ARCHITECTURE_NODE</span>
			</div>
			
			<div class="flex gap-8 font-tech text-[9px] tracking-widest">
				<a href="https://github.com/xlonglink" target="_blank" class="opacity-40 hover:opacity-100 hover:text-primary transition-all duration-300">GITHUB</a>
				<a href="https://www.linkedin.com/company/longlink" target="_blank" class="opacity-40 hover:opacity-100 hover:text-primary transition-all duration-300">LINKEDIN</a>
			</div>
		</div>

		<div class="text-right space-y-6">
			<div class="flex items-center justify-end gap-4">
				<div class="text-right">
					<p class="font-tech text-[9px] tracking-widest">&copy; {new Date().getFullYear()} LongLink SAGL all rights reserved.</p>
					<a href="/impressum" class="font-tech text-[8px] opacity-20 hover:opacity-100 hover:text-primary transition-all tracking-widest mt-2 block uppercase">Impressum</a>
				</div>
				<div class="w-8 h-[1px] bg-primary/30"></div>
			</div>
		</div>
	</div>
</footer>
